package main

import (
	"context"
	"fmt"
	"io"
	"net/http"
	"testing"
	"time"

	"github.com/githubVladimirT/bookserver-micro/internal"
	pb "github.com/githubVladimirT/bookserver-micro/proto"

	mhttp "go.unistack.org/micro-client-http/v3"
	jsoncodec "go.unistack.org/micro-codec-json/v3"
	"go.unistack.org/micro/v3/client"
	micro_logger "go.unistack.org/micro/v3/logger/slog"
	"go.unistack.org/micro/v3/logger"
)

func TestDebugMicroClient(t *testing.T) {
	ctx, cancel := context.WithCancel(context.Background())
	defer cancel()

	readyCh := make(chan struct{})
	shutdown, address := internal.InitServerWithReady(ctx, readyCh)
	defer shutdown()
	<-readyCh

	time.Sleep(100 * time.Millisecond)

	// Create client with just the codec
	c := mhttp.NewClient(
		client.Codec("application/json", jsoncodec.NewCodec()),
	)

	if err := c.Init(); err != nil {
		t.Fatalf("client init failed: %v", err)
	}

	cli := client.NewClientCallOptions(
		c,
		client.WithAddress(address),
	)

	mc := pb.NewBookServerClient("bookserver-micro-client", cli)

	req := &pb.Empty{}
	rsp, err := mc.Home(context.TODO(), req)
	if err != nil {
		t.Fatalf("Home call failed: %v", err)
	}

	t.Logf("Response: %+v", rsp)
}

func TestDebugMicroClientWithContentType(t *testing.T) {
	ctx, cancel := context.WithCancel(context.Background())
	defer cancel()

	readyCh := make(chan struct{})
	shutdown, address := internal.InitServerWithReady(ctx, readyCh)
	defer shutdown()
	<-readyCh

	time.Sleep(100 * time.Millisecond)

	// Create client with ContentType option
	c := mhttp.NewClient(
		client.ContentType("application/json"),
		client.Codec("application/json", jsoncodec.NewCodec()),
		client.Logger(micro_logger.NewLogger(logger.WithLevel(logger.DebugLevel))),
	)

	// Check client options BEFORE Init
	t.Logf("Client BEFORE Init - ContentType: %s", c.Options().ContentType)
	t.Logf("Client BEFORE Init - Codecs: %v", c.Options().Codecs)

	// Test direct codec lookup BEFORE Init
	opts := c.Options()
	if cf, ok := opts.Codecs["application/json"]; ok {
		t.Logf("Direct codec lookup BEFORE Init succeeded: %v", cf)
	} else {
		t.Logf("Direct codec lookup BEFORE Init FAILED for application/json")
	}

	if err := c.Init(); err != nil {
		t.Fatalf("client init failed: %v", err)
	}

	// Check client options AFTER Init
	t.Logf("Client AFTER Init - ContentType: %s", c.Options().ContentType)
	t.Logf("Client AFTER Init - Codecs: %v", c.Options().Codecs)
	
	// Test direct codec lookup AFTER Init
	opts = c.Options()
	if cf, ok := opts.Codecs["application/json"]; ok {
		t.Logf("Direct codec lookup AFTER Init succeeded: %v", cf)
	} else {
		t.Logf("Direct codec lookup AFTER Init FAILED for application/json")
	}

	req := &pb.Empty{}
	// Create request and check its content type
	microReq := c.NewRequest("bookserver-micro", "BookServer.Home", req)
	t.Logf("Request ContentType: %s", microReq.ContentType())
	t.Logf("Client pointer: %p", c)
	
	// Make raw HTTP request to check response headers
	httpURL := fmt.Sprintf("http://%s/", address)
	httpRsp, err := http.Get(httpURL)
	if err == nil {
		ct := httpRsp.Header.Get("Content-Type")
		t.Logf("HTTP Response Content-Type: '%s'", ct)
		t.Logf("HTTP Response Content-Type bytes: %v", []byte(ct))
		t.Logf("HTTP Response Status: %s", httpRsp.Status)
		t.Logf("HTTP Response ALL Headers: %v", httpRsp.Header)
		httpRsp.Body.Close()
	}
	
	// Make raw HTTP request with micro client headers to see what the server receives
	httpReq, _ := http.NewRequest(http.MethodGet, httpURL, nil)
	httpReq.Header.Set("Content-Type", "application/json")
	httpReq.Header.Set("Endpoint", "BookServer.Home")
	httpRsp2, err := http.DefaultClient.Do(httpReq)
	if err == nil {
		b, _ := io.ReadAll(httpRsp2.Body)
		httpRsp2.Body.Close()
		t.Logf("Micro-style HTTP Response Status: %s", httpRsp2.Status)
		t.Logf("Micro-style HTTP Response Body: %s", string(b))
	}
	
	// Check what codecs are registered
	t.Logf("Registered codecs BEFORE call: %v", c.Options().Codecs)
	for k := range c.Options().Codecs {
		t.Logf("Codec key '%s' bytes: %v", k, []byte(k))
	}

	// Try calling newCodec manually by calling Call directly
	rsp := &pb.StatusRsp{}
	t.Logf("About to call c.Call() on client %p", c)
	
	// Manually test newCodec by simulating what parseRsp does
	testCT := "application/json"
	if cf, ok := c.Options().Codecs[testCT]; ok {
		t.Logf("Manual newCodec simulation succeeded for '%s': %v", testCT, cf)
	} else {
		t.Logf("Manual newCodec simulation FAILED for '%s'", testCT)
	}
	
	// Make the micro client call and capture response details
	t.Logf("Making micro client call to address: %s", address)
	t.Logf("Request details - Service: %s, Method: %s, Endpoint: %s", microReq.Service(), microReq.Method(), microReq.Endpoint())
	
	// Try with proto client instead of direct Call
	mc := pb.NewBookServerClient("bookserver-micro-client", c)
	rsp2, err2 := mc.Home(context.TODO(), &pb.Empty{}, client.WithAddress(address))
	if err2 != nil {
		t.Logf("Proto client call also failed: %v", err2)
	} else {
		t.Logf("Proto client call succeeded: %+v", rsp2)
	}
	
	// Make HTTP request directly using the client's http client to see what it receives
	// This will help us understand if the issue is with the response or the codec lookup
	
	err = c.Call(context.TODO(), microReq, rsp, 
		client.WithAddress(address),
		mhttp.Method(http.MethodGet),
		mhttp.Path("/"),
	)
	if err != nil {
		t.Logf("Codecs AFTER failed call: %v", c.Options().Codecs)
		t.Logf("Error type: %T", err)
		t.Logf("Response object: %+v", rsp)
		t.Fatalf("Direct Call failed: %v", err)
	}

	t.Logf("Response: %+v", rsp)
}
